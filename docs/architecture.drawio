        <mxCell id="e2" style="" parent="1" source="scanner" target="debounce" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2label" value="all APs&#xa;(push_scan)" style="edgeLabel;html=1;align=center;fontSize=9;" parent="e2" vertex="1" connectable="0">
