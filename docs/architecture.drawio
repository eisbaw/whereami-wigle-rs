          <mxGeometry x="-0.2" relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sqlite" value="SQLite (WAL)&#xa;&#xa;• aps (resolved positions)&#xa;• not_found (negative cache)&#xa;• pending (offline queue)&#xa;• metadata (rate limit)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" parent="1" vertex="1">
