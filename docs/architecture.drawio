        </mxCell>

        <!-- Debounce module -->
        <mxCell id="debounce" value="debounce.rs&#xa;&#xa;Ring buffer (last N scans)&#xa;&#xa;is_stable(bssid):&#xa;  count ≥ M in N samples&#xa;&#xa;Filters: buses, phones,&#xa;hotspots (transient)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
