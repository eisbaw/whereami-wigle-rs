          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="resolver" value="resolver.rs&#xa;&#xa;1. Check aps cache&#xa;2. Check not_found cache&#xa;3. Query WiGLE (on miss)&#xa;4. On 404 → not_found&#xa;5. On error → pending&#xa;6. Return positioned APs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="500" y="350" width="220" height="150" as="geometry" />
