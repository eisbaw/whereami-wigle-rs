        <mxCell id="wigle" value="WiGLE API&#xa;api.wigle.net&#xa;&#xa;GET /v2/network/search&#xa;?netid=MAC&#xa;&#xa;→ trilat, trilong, ssid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;" parent="1" vertex="1">
