            <mxPoint y="-14" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="scanloop" value="main.rs&#xa;scan loop&#xa;&#xa;fast: every 10s&#xa;slow: every 60s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="319" width="120" height="100" as="geometry" />
