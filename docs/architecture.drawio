        <!-- Scanner module -->
        <mxCell id="scanner" value="scanner.rs&#xa;&#xa;nmcli rescan + list&#xa;(fallback: iw trigger/dump)&#xa;&#xa;Parse output →&#xa;Vec&lt;ScannedNetwork&gt;&#xa;(bssid, ssid, signal, ch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" vertex="1" parent="1">
