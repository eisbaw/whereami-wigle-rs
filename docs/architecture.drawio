        <mxCell id="trilat" value="trilaterate.rs&#xa;&#xa;1. filter_outliers()&#xa;   median pos → reject&#xa;   &gt; max(200m, 3×median_dist)&#xa;&#xa;2. weighted centroid&#xa;   weight = 10^(dBm/20)&#xa;&#xa;→ (lat, lon, accuracy_m)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;" parent="1" vertex="1">
